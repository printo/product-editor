# General Configuration
PORT=3000
BACKEND_PORT=8000
NODE_ENV=production

# Django Configuration
DJANGO_SECRET_KEY=your-production-secret-key-here-50-chars-minimum
DEBUG=0
ALLOWED_HOSTS=yourdomain.com,backend
STORAGE_ROOT=/app/storage

# Database Configuration
POSTGRES_DB=product_editor
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-secure-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# API Keys Configuration
DEVELOPMENT_API_KEY=your-dev-api-key
PRODUCTION_API_KEY=your-prod-api-key
TESTING_API_KEY=your-test-api-key

# Authentication & Tokens
AUTH_SECRET=your-auth-secret-min-32-chars
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_EXPIRY=24h
REFRESH_TOKEN_EXPIRY=7d

# CORS Configuration
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# Frontend Configuration
NEXT_PUBLIC_API_BASE_URL=https://yourdomain.com/api
NEXT_PUBLIC_DEVELOPMENT_API_KEY=your-dev-api-key

# Docker / Nginx
PUBLIC_HOST=yourdomain.com
DOMAIN_NAME=your-product-editor.local
