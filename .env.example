# ============================================
# Product Editor - Environment Configuration
# ============================================
#
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Update all values marked with <CHANGE_THIS>
# 3. Generate secrets: python -c "import secrets; print(secrets.token_urlsafe(50))"
# 4. Never commit .env to git!
#
# ============================================

# Enable production profile (Traefik proxy)
COMPOSE_PROFILES=prod

# ===============================
# Server / General Configuration
# ===============================
NODE_ENV=production
PORT=3000
BACKEND_PORT=8000

# ===============================
# Django Settings
# ===============================
DEBUG=0
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=<CHANGE_THIS_GENERATE_NEW_SECRET>

# Traefik handles HTTPS termination
SECURE_SSL_REDIRECT=False

# Your production domain (comma-separated)
ALLOWED_HOSTS=yourdomain.com,backend

# CORS - Only production domains (comma-separated)
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# ===============================
# Database Configuration
# ===============================
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5432
POSTGRES_USER=postgres
# IMPORTANT: Use a strong password!
POSTGRES_PASSWORD=<CHANGE_THIS_STRONG_PASSWORD>
POSTGRES_DB=product_editor

# Connection Pool Settings
DB_POOL_MAX=20
DB_POOL_MIN=2
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECTION_TIMEOUT_MS=2000

# ===============================
# API Keys Configuration
# ===============================
# Generate unique keys for each environment
# Format: editor_<env>_sk_<random_string>
DIRECT_API_KEY=<CHANGE_THIS_GENERATE_NEW_API_KEY>
EXTERNAL_API_KEY=<CHANGE_THIS_GENERATE_NEW_API_KEY>
TESTING_API_KEY=<CHANGE_THIS_GENERATE_NEW_API_KEY>

# ===============================
# Storage
# ===============================
STORAGE_DIR=/app/storage

# ===============================
# Authentication & Tokens
# ===============================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
AUTH_SECRET=<CHANGE_THIS_GENERATE_NEW_SECRET>
JWT_SECRET=<CHANGE_THIS_GENERATE_NEW_SECRET>
JWT_EXPIRY=24h
REFRESH_TOKEN_EXPIRY=7d

# ===============================
# Rate Limiting & Worker
# ===============================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
UPLOAD_RATE_LIMIT_MAX=10
WORKER_POLLING_INTERVAL=2000
WORKER_TIMEOUT_MINUTES=2
MAX_RETRIES=2
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=image/jpeg,image/jpg,image/png,image/webp,image/gif

# ===============================
# Frontend Configuration
# ===============================
# Use /api for Traefik routing in production
NEXT_PUBLIC_API_BASE_URL=/api
NEXT_PUBLIC_DEVELOPMENT_API_KEY=<SAME_AS_DIRECT_API_KEY>
FRONTEND_HOST_PORT=5004

# ===============================
# NextAuth Configuration
# ===============================
# Your production domain
AUTH_URL=https://yourdomain.com
NEXTAUTH_URL=https://yourdomain.com
AUTH_TRUST_HOST=true

# ===============================
# Docker / Traefik Configuration
# ===============================
PUBLIC_HOST=yourdomain.com
DOMAIN_NAME=yourdomain.com

# ===============================
# External Services
# ===============================
PIA_API_BASE_URL=https://pia.printo.in/api/v1

# ===============================
# Redis Configuration
# ===============================
REDIS_URL=redis://redis:6379/0

# ===============================
# Celery / Async Queue
# ===============================
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
# Worker slots per container (keep at 2 unless you raise memory limit proportionally)
CELERY_CONCURRENCY=2

# ===============================
# OMS Integration
# ===============================
OMS_PRODUCTION_ESTIMATOR_URL=https://oms.printo.in/api/production/estimate

# ===============================
# Storage (Render Outputs)
# ===============================
STORAGE_ROOT=/app/storage
EXPORTS_DIR=/app/storage/exports

# ===============================
# Gunicorn Configuration (Optional)
# ===============================
GUNICORN_WORKERS=4
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=300
GUNICORN_MAX_REQUESTS=500
GUNICORN_LOG_LEVEL=info
